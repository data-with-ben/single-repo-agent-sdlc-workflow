      "Bash(git commit:*)",
      "Bash(npm create:*)",
      "Bash(npm install)",
      "Bash(npm install:*)",
      "Bash(npm test:*)",
      "Bash(npm run build:*)",
      "Bash(git merge:*)",
      "Bash(git show-ref:*)",
      "Bash(npx playwright:*)",
      "Bash(dir:*)"
